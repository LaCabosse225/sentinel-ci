{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "cleanUrls": true,
    "redirects": [
      {
        "regex": "^/firebasejs/\\d+\\.\\d+\\.\\d+/(?P<fichier>.+)$",
        "destination": "/firebasejs/:fichier",
        "type": 302
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}